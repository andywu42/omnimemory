# ============================================================================
# OmniMemory - Environment Configuration
# ============================================================================
# Copy this file to .env and customize values as needed.
# All variables have sensible defaults - only override what you need.
#
# Usage:
#   cp .env.example .env
#   docker compose up -d
# ============================================================================

# ----------------------------------------------------------------------------
# Docker Image Versions
# ----------------------------------------------------------------------------
# These control which versions of the database images are used.
# Update these to upgrade or pin specific versions.

# Qdrant Vector Database
# Latest versions: https://hub.docker.com/r/qdrant/qdrant/tags
QDRANT_VERSION=v1.16.3

# Memgraph Graph Database
# Latest versions: https://hub.docker.com/r/memgraph/memgraph/tags
MEMGRAPH_VERSION=2.18.1

# ----------------------------------------------------------------------------
# Qdrant Configuration
# ----------------------------------------------------------------------------
# Vector database for semantic memory storage

# REST API port (default: 6333)
QDRANT_PORT=6333

# gRPC port for high-performance operations (default: 6334)
QDRANT_GRPC_PORT=6334

# ----------------------------------------------------------------------------
# Memgraph Configuration
# ----------------------------------------------------------------------------
# Graph database for relationship queries

# Bolt protocol port for client connections (default: 7687)
MEMGRAPH_BOLT_PORT=7687

# HTTP port for web interface (default: 7444)
MEMGRAPH_HTTP_PORT=7444
